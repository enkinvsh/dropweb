/service/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Helper
/services/helper/target/
#libclash
/libclash/

#jniLibs
# core/src/main/jniLibs is fully generated by `setup.dart` (libclash + cgo
# headers). It must stay ignored — committing it pollutes the repo with
# 40+ MB of regenerated artefacts on every core update.
/android/core/src/main/jniLibs/

# app/src/main/jniLibs holds an embedded native relay binary, built out
# of tree and copied in. The directory is tracked so release APKs ship
# the binary even on a clean CI checkout.

# Internal planning / release / infra docs — not shipped publicly
/docs/plans/
/docs/parazitx/
/docs/release/

# Signing keys (sensitive data)
/android/app/keystore.jks
/android/app/key.properties
/android/local.properties
*.jks
*.keystore
signing.properties

# Environment variables (contains sensitive data)
.env
*.local.sh

# Playwright baseline screenshots and session data
/baseline-*.png
/.playwright-mcp/

# OpenCode local config
.opencode/
opencode.json
# Sisyphus orchestration scratch
.sisyphus/

# Serena tooling metadata
.serena/

# code-graph-mcp local code index
.code-graph/

# Android module build output (artifacts; never track)
/android/build/

# fvm (local Flutter version pin)
.fvm/
.fvmrc
